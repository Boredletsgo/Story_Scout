# ===========================================================================
# Story Scout - docker compose environment overrides
#
# Copy this file to ".env" in the project root before running:
#   cp .env.docker.example .env
#   docker compose up --build
#
# Every value has a sensible default in docker-compose.yml, so the stack runs
# out-of-the-box with local open-source models (Ollama) and no API keys.
# ===========================================================================

# ---- General ----
ENVIRONMENT=production
# IMPORTANT: set a long, random value for any real deployment.
SECRET_KEY=please-change-this-in-production

# ---- LLM provider ----
# One of: ollama (default, offline) | openai | anthropic
LLM_PROVIDER=ollama

# Local Ollama model (pulled into the ollama service — see README).
OLLAMA_MODEL=llama3.1:8b

# Only needed if LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Embeddings always run locally (no key required).
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- Database ----
POSTGRES_USER=storyscout
POSTGRES_PASSWORD=storyscout
POSTGRES_DB=storyscout

# ---- Behaviour ----
ENABLE_MLFLOW=true
SEED_ON_START=true

# ---- Host port mappings (change if a port is already in use) ----
FRONTEND_HOST_PORT=3000
BACKEND_HOST_PORT=8000
POSTGRES_PORT=5432
CHROMA_HOST_PORT=8001
OLLAMA_HOST_PORT=11434
MLFLOW_HOST_PORT=5000
