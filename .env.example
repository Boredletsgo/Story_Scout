# ===========================================================================
# Story Scout - Environment configuration
# Copy to `.env` and adjust. `docker compose up` works with these defaults.
# ===========================================================================

# ---- General ----
ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
PROJECT_NAME=Story Scout

# ---- Security / Auth ----
# CHANGE THIS in production. Generate: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# ---- CORS (comma-separated) ----
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# ---- PostgreSQL ----
POSTGRES_USER=storyscout
POSTGRES_PASSWORD=storyscout
POSTGRES_DB=storyscout
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Override the whole URL if you want (async driver):
# DATABASE_URL=postgresql+asyncpg://storyscout:storyscout@postgres:5432/storyscout

# ---- ChromaDB (vector store) ----
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=storyscout_books

# ---- Embeddings (always local / free) ----
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- LLM PROVIDER ABSTRACTION ----------------------------------------------
# provider: one of [ollama, openai, anthropic]
# Default `ollama` => runs fully offline, no API key required.
LLM_PROVIDER=ollama

# Ollama (local OSS models)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# OpenAI (only used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (only used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Sampling defaults
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=1024

# ---- MLflow (MLOps) ----
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=storyscout-recommendations
ENABLE_MLFLOW=true

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:8000
