# Frontend environment
# Base URL the browser uses to reach the backend API.
# In dev with the Vite proxy, leave as /api (proxied to VITE_PROXY_TARGET).
# In Docker/production, set to the public backend origin, e.g. http://localhost:8000
VITE_API_BASE_URL=/api

# Dev-only: where the Vite dev server proxies /api requests.
VITE_PROXY_TARGET=http://localhost:8000
